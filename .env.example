# PostgreSQL
DATABASE_URL="postgresql://jeux:jeux_dev_pwd@127.0.0.1:5432/jeux?schema=public"

# Auth.js (générer: openssl rand -base64 32)
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3000"

# Service temps réel
REALTIME_PORT="4000"
NEXT_PUBLIC_REALTIME_URL="http://localhost:4000"
REALTIME_CORS_ORIGIN="http://localhost:3000"
# Autorise une identité de socket non signée (dev/tests uniquement)
ALLOW_DEV_AUTH="1"

# API partenaire (backend Symfony / API Platform)
# Boutiques/actualités/événements sont publics ; products + orders exigent un JWT.
RELIQUES_API_URL="https://reliques.theo-gambier.fr/api"
# Compte de service : le serveur s'y connecte (POST /api/login) pour lire le catalogue
# et créer les commandes. Crée un compte dédié via POST /api/register.
RELIQUES_SERVICE_EMAIL=""
RELIQUES_SERVICE_PASSWORD=""

# Stripe (optionnel : sans ces cles, le checkout valide la commande directement)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."   # fourni par `stripe listen`
